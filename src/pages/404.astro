---
import "@fontsource-variable/geist";
import "../styles/globals.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found — PromoClock</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta name="robots" content="noindex" />
  </head>
  <body class="font-sans antialiased bg-background text-foreground">
    <main
      style="min-height:100dvh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;text-align:center;padding:2rem;"
    >
      <h1 style="font-size:3rem;margin:0;">404</h1>
      <p style="color:var(--muted);max-width:28rem;">
        That page doesn’t exist. Head back to PromoClock to check Claude’s peak
        hours.
      </p>
      <a
        href="/en/"
        style="color:var(--primary);font-weight:600;text-decoration:underline;text-underline-offset:4px;"
        >Go to PromoClock →</a
      >
    </main>
  </body>
</html>
