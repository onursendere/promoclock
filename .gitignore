# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# astro
dist/
.astro/

# cloudflare (wrangler local state)
.wrangler/

# next.js (legacy build cache)
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local tooling (Claude Code preview config, etc.)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
